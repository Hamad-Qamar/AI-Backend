# Copy to `.env` for local runs. On Render / Railway / Fly / etc., set these in the
# platform secrets UI (never commit real keys).

# --- Phase-2 via Supabase (production / cloud) ---
PHASE2_SOURCE=supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional TLS: leave unset or true in production. Use false only if the host
# cannot verify certificates (some local Windows setups).
# SUPABASE_SSL_VERIFY=true

# Optional: higher Hugging Face Hub rate limits when downloading embedding models
# HF_TOKEN=

# Optional: after baking the model in Docker build (`Dockerfile`). Runtime then needs no Hub egress.
# HF_HOME=/app/.cache/huggingface
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
